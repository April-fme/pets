{
  "ConnectionStrings": {
    "PetsDatabase": "Server=localhost;Database=PetsDB;Trusted_Connection=True;TrustServerCertificate=True;",
    
    "// 選項1: SQL Server Express (命名實例)": "",
    "PetsDatabase_SqlExpress": "Server=localhost\\SQLEXPRESS;Database=PetsDB;Trusted_Connection=True;TrustServerCertificate=True;",
    
    "// 選項2: SQL Server 使用帳號密碼": "",
    "PetsDatabase_WithLogin": "Server=localhost;Database=PetsDB;User Id=sa;Password=YourPassword;TrustServerCertificate=True;",
    
    "// 選項3: SQLite (輕量級，不需安裝 SQL Server)": "",
    "PetsDatabase_SQLite": "Data Source=pets.db",
    
    "// 選項4: Azure SQL Database": "",
    "PetsDatabase_Azure": "Server=tcp:yourserver.database.windows.net,1433;Database=PetsDB;User ID=yourusername;Password=yourpassword;Encrypt=True;TrustServerCertificate=False;"
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  
  "AllowedHosts": "*",
  
  "// 說明": {
    "ConnectionStrings": "請根據您的資料庫類型選擇對應的連線字串，並更新 appsettings.json 中的 PetsDatabase",
    "SQL Server Express": "如果使用 SQL Server Express，實例名稱通常是 SQLEXPRESS",
    "Trusted_Connection": "Windows 驗證，使用當前 Windows 使用者登入",
    "User Id/Password": "SQL Server 驗證，需提供帳號密碼",
    "SQLite": "如要改用 SQLite，需安裝套件: dotnet add package Microsoft.EntityFrameworkCore.Sqlite，並修改 Program.cs 中的 UseSqlServer 為 UseSqlite"
  }
}
